APP_NAME=Hotel IT Operations Portal
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
DATABASE_URL=postgresql+psycopg2://hiop:REPLACE_DATABASE_PASSWORD@db:5432/hiop
SECRET_KEY=REPLACE_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=["https://hiop.example.com"]
LOG_LEVEL=INFO
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE_SECONDS=1800
SCHEDULER_ENABLED=true
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=
